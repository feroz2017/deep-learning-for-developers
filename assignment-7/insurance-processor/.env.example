# ── Google Cloud API keys (Vision / NLP / Translation) ──────────────────────
GOOGLE_VISION_API_KEY=your_google_api_key
GOOGLE_NLP_API_KEY=your_google_api_key
GOOGLE_TRANSLATE_API_KEY=your_google_api_key

# ── Azure AI Vision (Computer Vision) ───────────────────────────────────────
AZURE_VISION_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_VISION_KEY=your_azure_vision_key

# ── Azure Language Service ───────────────────────────────────────────────────
AZURE_LANGUAGE_ENDPOINT=https://<resource>.cognitiveservices.azure.com
AZURE_LANGUAGE_KEY=your_azure_language_key

# ── Google Gemini (LLM written report) ───────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GOOGLE_GEMINI_MODEL=gemini-2.0-flash
GOOGLE_GEMINI_FALLBACK_MODEL=gemini-flash-latest

# ── Optional ─────────────────────────────────────────────────────────────────
MAX_PDF_PAGES=3
